{
  "name": "concentrate-hiring-quiz",
  "version": "1.0.0",
  "description": "Concentrate.ai Hiring Quiz",
  "private": true,
  "scripts": {
    "predev": "npm run build:server",
    "dev": "concurrently -n tsc,server,web -c yellow,blue,green \"npm:watch:server\" \"npm:dev:server\" \"npm:dev:client\"",
    "dev:client": "next dev",
    "build:server": "tsc -p tsconfig.server.json",
    "build:client": "next build",
    "build": "npm run build:server && npm run build:client",
    "watch:server": "tsc -p tsconfig.server.json --watch",
    "start:server": "node --env-file=.env dist/server.js",
    "start:client": "next start",
    "start": "concurrently -n server,web -c blue,green \"npm:start:server\" \"npm:start:client\"",
    "dev:server": "node --env-file=.env --watch dist/server.js",
    "db:migrate": "npm run build:server && node --env-file=.env dist/db/migrate.js up",
    "db:migrate:down": "npm run build:server && node --env-file=.env dist/db/migrate.js down",
    "db:migrate:test": "npm run build:server && node --env-file=.env.test dist/db/migrate.js up",
    "db:seed:e2e": "npm run build:server && node --env-file=.env dist/db/seedE2e.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "type-check": "tsc --noEmit",
    "coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "lint": "eslint .",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "@testing-library/jest-dom": "^6.5.0",
    "@testing-library/react": "^16.0.1",
    "@testing-library/user-event": "^14.5.2",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.10.2",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@typescript-eslint/eslint-plugin": "^8.18.2",
    "@typescript-eslint/parser": "^8.18.2",
    "@vitest/coverage-v8": "^2.1.8",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "eslint": "^9.17.0",
    "eslint-config-next": "^15.1.3",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^5.0.0",
    "jsdom": "^25.0.1",
    "postcss": "^8.4.49",
    "prettier": "^3.4.2",
    "prettier-plugin-tailwindcss": "^0.6.9",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "vite": "^6.0.5",
    "vitest": "^2.1.8"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^10.0.1",
    "@radix-ui/react-dialog": "^1.1.4",
    "@radix-ui/react-dropdown-menu": "^2.1.4",
    "fastify": "^5.2.0",
    "ioredis": "^5.4.2",
    "jsonwebtoken": "^9.0.2",
    "kysely": "^0.27.4",
    "lucide-react": "^0.468.0",
    "next": "^15.1.3",
    "pg": "^8.13.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "resend": "^6.17.2",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^3.24.1"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  }
}
