NODE_ENV=development
PORT=4000

DATABASE_URL=postgres://postgres:postgres@localhost:5433/concentrate-quiz
REDIS_URL=redis://localhost:6379

JWT_SECRET=replace-with-a-long-random-hex-string
JWT_REFRESH_SECRET=replace-with-a-different-long-random-hex-string
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

COOKIE_SECRET=replace-with-a-long-random-hex-string

# Google OAuth (optional). Create a Web application OAuth client at
# https://console.cloud.google.com/apis/credentials with an authorized
# redirect URI matching GOOGLE_REDIRECT_URI below. Leave blank to disable
# "Sign in with Google" (the app runs fine without it).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:4000/api/auth/google/callback

# Base URL of the Next.js frontend, used for OAuth redirects
FRONTEND_URL=http://localhost:3000

# Base URL the browser uses to reach the API (src/lib/api.ts). Leave blank to
# use same-origin requests proxied by next.config.mjs rewrites (the default
# for local dev and for the single-container Docker setup).
NEXT_PUBLIC_API_URL=

# AI chatbot integration (optional, leave key blank to disable and fall back
# to the deterministic mock assistant). Defaults point at the NVIDIA NIM
# OpenAI-compatible endpoint.
AI_API_KEY=
AI_BASE_URL=https://integrate.api.nvidia.com/v1
AI_MODEL=google/diffusiongemma-26b-a4b-it

# Transactional email for password reset (optional in dev/test - throws a
# clear error only if actually invoked outside test env with this unset).
# Get a key at https://resend.com/api-keys
RESEND_API_KEY=
EMAIL_FROM=Concentrate Portal <no-reply@concentrate-portal.app>
